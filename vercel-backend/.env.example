# Copy this to .env.local for local testing
# Set these in Vercel Dashboard → Settings → Environment Variables

# Azure App Registration (any Microsoft account, free)
# portal.azure.com → App registrations → New registration
CLIENT_ID=your-client-id-here
CLIENT_SECRET=your-client-secret-here

# Use "common" so any Microsoft org can log in
TENANT_ID=common

# Your Vercel app URL (set after first deploy)
VERCEL_URL=https://your-app.vercel.app

# Secret key to protect the /api/send-email endpoint
# Generate any random string: openssl rand -hex 32
API_KEY=change-this-to-a-random-secret
